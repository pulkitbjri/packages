rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isParticipant() {
      return isSignedIn() &&
        request.auth.uid in resource.data.participantIds;
    }

    function requestParticipantIds() {
      return request.resource.data.participantIds;
    }

    function isCreatingOwnThread() {
      return isSignedIn() &&
        requestParticipantIds() is list &&
        request.auth.uid in requestParticipantIds() &&
        request.resource.data.unreadCount[request.auth.uid] == 0;
    }

    match /chats/{chatId} {
      allow read: if isParticipant();
      allow create: if isCreatingOwnThread();
      allow update: if isParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in request.resource.data.readBy;
        allow update: if false;
        allow delete: if false;
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
